# =============================================================================
# AgroElevate Web — Environment Variables (placeholders only)
# Copy to .env and fill in your values. NEVER commit .env to Git.
# =============================================================================

# --- Required (Supabase) ---
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# --- Required for AI dashboards / Copilot ---
# Local: http://localhost:8000  |  Production: your deployed AI service URL
VITE_AI_API_URL=http://localhost:8000

# --- Optional (Razorpay public key — only if client-side Checkout needs it) ---
# Wallet top-up uses Supabase Edge Functions; key_id is usually returned by the server.
# VITE_RAZORPAY_KEY_ID=rzp_test_xxxxxxxx

# =============================================================================
# NOT for frontend / Vercel — server-side & CI only
# =============================================================================
# SUPABASE_SERVICE_ROLE_KEY=     # commerce-verify.mjs harness ONLY — never in Vite bundle
# SUPABASE_DB_URL=               # migration scripts only
#
# Supabase Edge Function secrets (Dashboard → Edge Functions → Secrets):
#   RAZORPAY_KEY_ID, RAZORPAY_KEY_SECRET, RAZORPAY_WEBHOOK_SECRET
#
# AI service (ai-service/.env — see ai-service/.env.example):
#   SUPABASE_URL, SUPABASE_SERVICE_ROLE_KEY, ALLOWED_ORIGINS
