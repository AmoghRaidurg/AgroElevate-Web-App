# Market Intelligence — Official Government API Keys (optional)
# Copy to .env and set values obtained from official registration only.

# data.gov.in — REQUIRED for live mandi prices (official OGD API)
# Register at https://data.gov.in → My Account → Generate API Key
DATA_GOV_API_KEY=

# AGMARKNET — No direct public REST API exists as of audit date.
# Official AGMARKNET mandi data is published via data.gov.in (see DATA_GOV_API_KEY).
# This variable is reserved for future official AGMARKNET API if released.
AGMARKNET_API_KEY=

# eNAM — No public developer API; integration requires SFAC empanelment.
# Reserved for future official credentials if provided by SFAC.
ENAM_API_KEY=

# Optional overrides
DATA_GOV_IN_BASE_URL=https://api.data.gov.in
DATA_GOV_IN_RESOURCE_ID=9ef84268-d588-465a-a308-a864a43d0070
MARKET_INTEL_CACHE_TTL_HOURS=6
DATA_GOV_API_TIMEOUT_SEC=5
MARKET_INTEL_CIRCUIT_FAILURES=3
MARKET_INTEL_CIRCUIT_OPEN_MINUTES=30
